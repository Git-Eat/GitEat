<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.giteat.notification.daemon.mapper.NotificationMapper">

    <!-- 알림 리스트 조회 -->
    <select id="selectNotiList" resultType="com.giteat.notification.daemon.dto.NotificationDto">
        SELECT id, message, created_at, processed
        FROM notifications
        WHERE url = #{url}
    </select>

</mapper>
