<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.giteat.noti.mapper.NotiMapper">

    <!-- 레포지토리 토큰 삽입 -->
    <insert id="saveNotiToken" parameterType="notiDto">
        INSERT INTO noti_token (repo_id, user_id, noti_token)
        VALUES (#{repoId}, #{userId}, #{notiToken})
    </insert>



</mapper>
